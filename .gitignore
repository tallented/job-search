# OS and Office temp files
.DS_Store
~$*

# Python cache
__pycache__/
*.pyc

# Generated resume text cache
_resume_text/
_resume_text_archive/

# Local NocoDB runtime/state
job-tracker/data/
job-tracker/import/*.csv

# Legacy archived workbook copies
bak/

# Local generated/temp artifacts
.tmp.driveupload/
.tmpql*/

# Local manual Word repair/backups
* - backup *.docx
* backup *.docx
* - pre-* backup.docx
* - pre-*.docx
* - unreadable-backup.docx
* - rebuilt*.docx
Backups/

# Generated preview/scratch PDFs
*.preview.pdf
* - fresh.pdf

# Historical rendered PDFs; source docs remain tracked
Old Versions/**/*.pdf
prior revisions/**/*.pdf
Version - */*.pdf

# Non-resume design assets kept out of this repo for now
Business Cards/

# Low-signal nested workspace leftovers
Send To/**/old/
Submitted/**/old/
Submitted/**/agent screenshots/
